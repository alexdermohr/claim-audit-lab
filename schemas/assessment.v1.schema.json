{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claim-audit-lab/schemas/assessment.v1.schema.json",
  "title": "Assessment v1",
  "description": "A structured case assessment with lifecycle and verdict.",
  "type": "object",
  "required": [
    "schema_version",
    "assessment_id",
    "case_ref",
    "status",
    "lifecycle",
    "verdict",
    "redteam_ref"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "assessment_id": {
      "type": "string",
      "pattern": "^a[0-9]{3,}$"
    },
    "case_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "assessed",
        "contested",
        "redteam_blocked",
        "final_under_uncertainty",
        "reopened",
        "superseded",
        "archived"
      ]
    },
    "redteam_ref": {
      "type": "string",
      "minLength": 1
    },
    "redteam_status": {
      "type": "string",
      "enum": ["passed", "blocked", "passed_with_notes", "pending"]
    },
    "lifecycle": {
      "type": "object",
      "required": ["created_at", "last_reviewed_at", "review_after"],
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "last_reviewed_at": {
          "type": "string",
          "format": "date"
        },
        "review_after": {
          "type": "string",
          "format": "date"
        },
        "reopen_triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "new_primary_source",
              "major_contradiction",
              "source_discredited",
              "legal_update",
              "dataset_revision"
            ]
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "established": { "type": "array", "items": { "type": "string" } },
        "strongly_supported": { "type": "array", "items": { "type": "string" } },
        "plausible": { "type": "array", "items": { "type": "string" } },
        "weak": { "type": "array", "items": { "type": "string" } },
        "speculative": { "type": "array", "items": { "type": "string" } },
        "contradicted": { "type": "array", "items": { "type": "string" } },
        "unresolved": { "type": "array", "items": { "type": "string" } },
        "no_verdict_possible": { "type": "array", "items": { "type": "string" } }
      }
    },
    "claim_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string"
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "causes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "interpolation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mandatory_statement": {
      "type": "string",
      "const": "This assessment is not a truth certificate. It is an evidence-structured judgment under declared uncertainty."
    }
  }
}
