{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claim-audit-lab/schemas/hypothesis-support-ledger.v1.schema.json",
  "title": "Hypothesis Support Ledger v1",
  "description": "Procedural support-search records for hypotheses; enforces search symmetry, not evidential equality.",
  "type": "object",
  "required": [
    "schema_version",
    "case_ref",
    "audited_at",
    "auditor",
    "records"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "case_ref": {
      "type": "string",
      "minLength": 1
    },
    "audited_at": {
      "type": "string",
      "format": "date"
    },
    "auditor": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "hypothesis_ref",
          "support_search_status",
          "strongest_supporting_argument",
          "supporting_evidence_refs",
          "best_supporting_source_refs",
          "steelman",
          "missing_for_upgrade",
          "searched_for",
          "not_found",
          "notes",
          "support_quality_score"
        ],
        "additionalProperties": false,
        "properties": {
          "hypothesis_ref": {
            "type": "string",
            "minLength": 1
          },
          "support_search_status": {
            "type": "string",
            "enum": ["completed", "blocked", "not_applicable"]
          },
          "strongest_supporting_argument": {
            "type": "string",
            "minLength": 1
          },
          "supporting_evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "best_supporting_source_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "steelman": {
            "type": "string",
            "minLength": 1
          },
          "missing_for_upgrade": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "searched_for": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "not_found": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": {
            "type": "string",
            "minLength": 1
          },
          "support_quality_score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    }
  }
}
