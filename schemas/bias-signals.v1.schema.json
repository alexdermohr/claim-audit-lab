{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claim-audit-lab/schemas/bias-signals.v1.schema.json",
  "title": "Bias Signals v1",
  "description": "Machine-derived bias signals for a case. Generated, never hand-edited.",
  "type": "object",
  "required": ["schema_version", "case_ref", "generated_by", "signals"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "case_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "signal_id",
          "signal_type",
          "severity",
          "affected_claims",
          "detected_from",
          "observation",
          "required_response"
        ],
        "additionalProperties": false,
        "properties": {
          "signal_id": {
            "type": "string",
            "pattern": "^bs_[0-9a-f]{12}$"
          },
          "signal_type": {
            "type": "string",
            "enum": [
              "assessment_verdict_mismatch",
              "relation_threshold_proximity",
              "source_weight_asymmetry",
              "reported_claim_world_pressure",
              "comparative_claim_underframed",
              "redteam_pending_with_final_language",
              "counterhypothesis_understeelman"
            ]
          },
          "severity": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "affected_claims": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "detected_from": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "observation": {
            "type": "string",
            "minLength": 1
          },
          "required_response": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
