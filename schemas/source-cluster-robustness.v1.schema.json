{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claim-audit-lab/schemas/source-cluster-robustness.v1.schema.json",
  "title": "Source Cluster Robustness v1",
  "description": "Case-local audit of dominant source clusters and verdict fragility under cluster-knockout stress tests.",
  "type": "object",
  "required": ["schema_version", "case_ref", "clusters", "knockout_tests"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "case_ref": {"type": "string", "minLength": 1},
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "source_refs", "cluster_role"],
        "additionalProperties": false,
        "properties": {
          "cluster_id": {"type": "string", "minLength": 1},
          "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "cluster_role": {
            "type": "string",
            "enum": [
              "primary_investigation",
              "official_summary",
              "expert_report",
              "advocacy_report",
              "corporate_report",
              "academic_study",
              "media_investigation",
              "witness_collection",
              "secondary_synthesis",
              "anti_official_cluster",
              "independent_replication"
            ]
          },
          "independence_risk": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "compromise_scenarios": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["scenario_id", "premise", "treatment"],
              "additionalProperties": false,
              "properties": {
                "scenario_id": {"type": "string", "minLength": 1},
                "premise": {"type": "string", "minLength": 1},
                "treatment": {
                  "type": "string",
                  "enum": [
                    "downgrade_to_reported_claim_only",
                    "remove_from_world_claim_support",
                    "require_independent_replication",
                    "cap_negative_closure"
                  ]
                },
                "affected_claims": {"type": "array", "items": {"type": "string", "minLength": 1}},
                "rationale": {"type": "string"},
                "notes": {"type": "string"}
              }
            }
          },
          "notes": {"type": "string"}
        }
      }
    },
    "knockout_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "removed_cluster_refs", "affected_claims", "verdict_without_cluster"],
        "additionalProperties": false,
        "properties": {
          "test_id": {"type": "string", "minLength": 1},
          "removed_cluster_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "affected_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "verdict_without_cluster": {
            "type": "string",
            "enum": [
              "established",
              "strongly_supported",
              "plausible",
              "weak",
              "speculative",
              "contradicted",
              "unresolved",
              "no_verdict_possible"
            ]
          },
          "verdict_delta": {"type": "string"},
          "fragility_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "rationale": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
